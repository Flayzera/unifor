# Copie este arquivo para .env e preencha (o nome deve ser exatamente .env)
# Depois PARE e rode de novo: npm run dev

# Em `npm run dev` o front ignora esta URL e usa o proxy do Vite (sem CORS).
# Em produção (build): URL pública da API.
VITE_API_URL=

# Firebase — mesmo projeto do backend (Firestore / Auth)
# Console Firebase → Engrenagem "Configurações do projeto" → "Seus apps" → app Web
# Se não existir app Web, clique em "</>" e registre o app; copie o objeto firebaseConfig.
# NÃO use aspas nos valores. Sem espaços antes/depois do =.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
